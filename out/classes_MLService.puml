  include_xyz : bool
  local_hour_harmonics : int
  utc_hour_harmonics : int
  __init__(self, annual_harmonics: int, utc_hour_harmonics: int, local_hour_harmonics: int, include_xyz: bool, include_altitude_polynomials: bool, include_altitude_directional_terms: bool) -> None
  to_dict() -> Dict
}
class "WeatherPredictionService" as era5_gam_weather.prediction_service.WeatherPredictionService {
  artifact_dir : Path
  data_root : Path
  default_model_loaded : bool
  default_year : int
