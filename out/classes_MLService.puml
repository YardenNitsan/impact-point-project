  save(path: str) -> None
}
class "WeatherTreeTrainer" as era5_gam_weather.tree_model.WeatherTreeTrainer {
  feature_builder
  model_configs : dict
  target_names : tuple
  __init__(feature_builder: TreeFeatureBuilder | None, model_configs: Dict[str, Dict] | None, target_names: Iterable[str] | None)
  fit(features: Dict[str, np.ndarray], targets: Dict[str, np.ndarray], sample_weight: np.ndarray | Dict[str, np.ndarray | None] | None) -> 'WeatherTreeBundle'
}
era5_gam_weather.tree_model.WeatherTreeTrainer --> era5_gam_weather.tree_features.TreeFeatureBuilder : feature_builder
