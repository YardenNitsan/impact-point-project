# =========================
frontend/src/app.zip

# =========================
# ML generated files
# =========================
services/ML_service/dataset.jsonl

services/ML_service/artifacts/training_plots
services/ML_service/artifacts/replotted_training_curves
services/ML_service/.venv*

# =========================
# KNN generated files
# =========================
# dataset.npz and metadata.json are produced by train_knn.py / startup
# bootstrap and are machine-specific — do not commit them.
