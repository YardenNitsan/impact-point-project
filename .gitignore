# Cesium huge files
frontend/src/assets/cesium/
frontend/public/cesium/

# =========================
# Dev-only folders
# =========================
.dev/

# =========================
# Claude Code local settings (per-user, not shared)
# =========================
.claude/settings.local.json

# =========================
# Scripts
# =========================
# Keep scripts code, ignore only virtualenvs inside scripts
scripts/.venv/
scripts/venv/

# =========================
